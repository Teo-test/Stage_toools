#!/bin/bash
# =============================================================================
#  run_aster — Soumission de calculs Code_Aster via Slurm
# =============================================================================
#
#  Usage : run_aster [OPTIONS] [DOSSIER_ETUDE]
#
#  Détecte automatiquement le .comm et le maillage dans DOSSIER_ETUDE
#  (défaut : répertoire courant), copie tout dans /scratch/$USER/ sur le
#  nœud login (système de fichiers partagé), génère le .export, puis soumet
#  le job Slurm. Les résultats restent dans le dossier scratch.
#
#  Auteur   : généré pour localcluster
#  Version  : 2.0
# =============================================================================

set -euo pipefail

# ══════════════════════════════════════════════════════════════════════════════
#  CONFIGURATION — modifier ici selon l'installation
# ══════════════════════════════════════════════════════════════════════════════

# Chemin vers Code_Aster (surchargeable par variable d'environnement)
ASTER_ROOT="${ASTER_ROOT:-/opt/code_aster}"

# Nom du module Lmod à charger (laisser vide si pas de module)
ASTER_MODULE="${ASTER_MODULE:-code_aster}"

# Répertoire scratch partagé (accessible depuis login ET nœuds de calcul)
# Surchargeable : SCRATCH_BASE=/mon/chemin ./run_aster ...
SCRATCH_BASE="${SCRATCH_BASE:-/scratch}"

# Image Singularity contenant Code_Aster (laisser vide si installation native)
# Surchargeable : SINGULARITY_IMAGE=/autre/image.sif ./run_aster ...
SINGULARITY_IMAGE="${SINGULARITY_IMAGE:-/home/teole/aster/salome_meca-lgpl-2024.1.0-1-20240327-scibian-11.sif}"
# Exécutable Code_Aster à l'intérieur de l'image Singularity
SINGULARITY_ASTER_EXE="/opt/salome_meca/V2024.1.0_scibian_univ/tools/Code_aster_stable-1670/bin/run_aster"

# ── Valeurs par défaut Slurm ──────────────────────────────────────────────────
DEFAULT_PARTITION="compute"
DEFAULT_NODES=1
DEFAULT_NTASKS=4
DEFAULT_CPUS_PER_TASK=1
DEFAULT_MEM="4G"
DEFAULT_TIME="24:00:00"

# ── Préréglages de ressources (-P court | -P moyen | -P long) ─────────────────
#    Modifiez ces lignes pour les adapter aux partitions de votre cluster.
PRESET_COURT_PARTITION="compute" ; PRESET_COURT_NTASKS=2 ; PRESET_COURT_MEM="2G"  ; PRESET_COURT_TIME="02:00:00"
PRESET_MOYEN_PARTITION="compute" ; PRESET_MOYEN_NTASKS=4 ; PRESET_MOYEN_MEM="8G"  ; PRESET_MOYEN_TIME="24:00:00"
PRESET_LONG_PARTITION="compute"  ; PRESET_LONG_NTASKS=8  ; PRESET_LONG_MEM="32G"  ; PRESET_LONG_TIME="72:00:00"

# ══════════════════════════════════════════════════════════════════════════════
#  AFFICHAGE
# ══════════════════════════════════════════════════════════════════════════════
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

info()    { echo -e "${BLUE}[INFO]${NC}  $*"; }
ok()      { echo -e "${GREEN}[ OK ]${NC}  $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()     { echo -e "${RED}[ ERR]${NC}  $*" >&2; }
section() { echo -e "\n${BOLD}${CYAN}▶ $*${NC}"; echo -e "${CYAN}$(printf '─%.0s' {1..60})${NC}"; }

# ══════════════════════════════════════════════════════════════════════════════
#  AIDE
# ══════════════════════════════════════════════════════════════════════════════
usage() {
    cat <<EOF
${BOLD}USAGE${NC}
  run_aster [OPTIONS] [DOSSIER_ETUDE]

  Lance un calcul Code_Aster via Slurm.
  Les fichiers sont copiés dans ${SCRATCH_BASE}/\$USER/ avant soumission.
  Par défaut, DOSSIER_ETUDE = répertoire courant.

${BOLD}FICHIERS${NC}
  -C, --comm FILE      Fichier .comm  (auto-détecté si absent)
  -M, --med  FILE      Fichier .med   (auto-détecté si absent)
  -A, --mail FILE      Fichier .mail  (format ASTER natif, auto-détecté si absent)

${BOLD}RESSOURCES SLURM${NC}
  -p, --partition NOM  Partition        [défaut: ${DEFAULT_PARTITION}]
  -n, --nodes     N    Nombre de nœuds  [défaut: ${DEFAULT_NODES}]
  -t, --ntasks    N    Tâches MPI       [défaut: ${DEFAULT_NTASKS}]
  -c, --cpus      N    CPUs par tâche   [défaut: ${DEFAULT_CPUS_PER_TASK}]
  -m, --mem       MEM  Mémoire/nœud     [défaut: ${DEFAULT_MEM}]
  -T, --time  H:M:S   Durée max        [défaut: ${DEFAULT_TIME}]

${BOLD}PRÉRÉGLAGES${NC}
  -P, --preset NOM     Préréglage de ressources (court, moyen, long)
                         court : ${PRESET_COURT_NTASKS} tâches, ${PRESET_COURT_MEM}, ${PRESET_COURT_TIME}
                         moyen : ${PRESET_MOYEN_NTASKS} tâches, ${PRESET_MOYEN_MEM}, ${PRESET_MOYEN_TIME}
                         long  : ${PRESET_LONG_NTASKS} tâches, ${PRESET_LONG_MEM}, ${PRESET_LONG_TIME}
                       Les options -n -t -m -T passées après -P surchargent le préréglage.

${BOLD}OPTIONS${NC}
  -l, --local          Exécution directe sans Slurm (test local, Singularity auto)
  -w, --wait           Suivre les logs en temps réel jusqu'à la fin
  -q, --quiet          Sortie minimale (juste le job ID)
  -h, --help           Afficher cette aide

${BOLD}EXEMPLES${NC}
  run_aster                              # Étude dans le dossier courant
  run_aster ~/calculs/poutre/            # Spécifier le dossier
  run_aster -P court                     # Préréglage court  (2 h)
  run_aster -P moyen                     # Préréglage moyen  (24 h)
  run_aster -P long                      # Préréglage long   (72 h)
  run_aster -P moyen -t 8                # Moyen mais 8 tâches MPI
  run_aster -n 2 -t 8 -m 8G --wait      # Personnalisé + suivi direct
  run_aster -p debug -T 01:00:00        # Partition debug, 1h max
  run_aster -C mon_calcul.comm -M maillage.med
  run_aster -C mon_calcul.comm -A maillage.mail

${BOLD}VARIABLES D'ENVIRONNEMENT${NC}
  ASTER_ROOT    Chemin vers Code_Aster (défaut: /opt/code_aster)
  ASTER_MODULE  Nom du module Lmod      (défaut: code_aster)
EOF
    exit 0
}

# ══════════════════════════════════════════════════════════════════════════════
#  PARSING DES ARGUMENTS
# ══════════════════════════════════════════════════════════════════════════════
STUDY_DIR="."
COMM_FILE=""
MED_FILE=""
MAIL_FILE=""
PRESET=""
PARTITION=""
NODES=""
NTASKS=""
CPUS=""
MEM=""
TIME_LIMIT=""
WAIT=false
QUIET=false
LOCAL=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -C|--comm)       COMM_FILE="$2";    shift 2 ;;
        -M|--med)        MED_FILE="$2";     shift 2 ;;
        -A|--mail)       MAIL_FILE="$2";    shift 2 ;;
        -P|--preset)     PRESET="$2";       shift 2 ;;
        -p|--partition)  PARTITION="$2";    shift 2 ;;
        -n|--nodes)      NODES="$2";        shift 2 ;;
        -t|--ntasks)     NTASKS="$2";       shift 2 ;;
        -c|--cpus)       CPUS="$2";         shift 2 ;;
        -m|--mem)        MEM="$2";          shift 2 ;;
        -T|--time)       TIME_LIMIT="$2";   shift 2 ;;
        -l|--local)      LOCAL=true;         shift ;;
        -w|--wait)       WAIT=true;         shift ;;
        -q|--quiet)      QUIET=true;        shift ;;
        -h|--help)       usage ;;
        -*)              err "Option inconnue : $1"; echo ""; usage ;;
        *)               STUDY_DIR="$1";    shift ;;
    esac
done

# ── Application du préréglage (les options explicites ont priorité) ────────────
if [ -n "$PRESET" ]; then
    case "${PRESET,,}" in
        court|short)
            : "${PARTITION:=$PRESET_COURT_PARTITION}"
            : "${NTASKS:=$PRESET_COURT_NTASKS}"
            : "${MEM:=$PRESET_COURT_MEM}"
            : "${TIME_LIMIT:=$PRESET_COURT_TIME}"
            $QUIET || info "Préréglage : court  (${PRESET_COURT_NTASKS} tâches, ${PRESET_COURT_MEM}, ${PRESET_COURT_TIME})"
            ;;
        moyen|medium)
            : "${PARTITION:=$PRESET_MOYEN_PARTITION}"
            : "${NTASKS:=$PRESET_MOYEN_NTASKS}"
            : "${MEM:=$PRESET_MOYEN_MEM}"
            : "${TIME_LIMIT:=$PRESET_MOYEN_TIME}"
            $QUIET || info "Préréglage : moyen  (${PRESET_MOYEN_NTASKS} tâches, ${PRESET_MOYEN_MEM}, ${PRESET_MOYEN_TIME})"
            ;;
        long)
            : "${PARTITION:=$PRESET_LONG_PARTITION}"
            : "${NTASKS:=$PRESET_LONG_NTASKS}"
            : "${MEM:=$PRESET_LONG_MEM}"
            : "${TIME_LIMIT:=$PRESET_LONG_TIME}"
            $QUIET || info "Préréglage : long   (${PRESET_LONG_NTASKS} tâches, ${PRESET_LONG_MEM}, ${PRESET_LONG_TIME})"
            ;;
        *) err "Préréglage inconnu : '$PRESET'  (valeurs acceptées : court, moyen, long)"; exit 1 ;;
    esac
fi
# Valeurs par défaut pour tout paramètre non fixé par option ou préréglage
: "${PARTITION:=$DEFAULT_PARTITION}"
: "${NODES:=$DEFAULT_NODES}"
: "${NTASKS:=$DEFAULT_NTASKS}"
: "${CPUS:=$DEFAULT_CPUS_PER_TASK}"
: "${MEM:=$DEFAULT_MEM}"
: "${TIME_LIMIT:=$DEFAULT_TIME}"

# ══════════════════════════════════════════════════════════════════════════════
#  DÉTECTION DES FICHIERS
# ══════════════════════════════════════════════════════════════════════════════
$QUIET || section "Détection de l'étude"

STUDY_DIR="$(realpath "$STUDY_DIR")"
STUDY_NAME="$(basename "$STUDY_DIR")"

[ -d "$STUDY_DIR" ] || { err "Dossier introuvable : $STUDY_DIR"; exit 1; }

$QUIET || info "Dossier  : $STUDY_DIR"
$QUIET || info "Étude    : $STUDY_NAME"

# ── Fichier .comm ─────────────────────────────────────────────────────────────
if [ -z "$COMM_FILE" ]; then
    mapfile -t COMM_LIST < <(find "$STUDY_DIR" -maxdepth 1 -name "*.comm" | sort)
    case ${#COMM_LIST[@]} in
        0) err "Aucun fichier .comm dans $STUDY_DIR"; exit 1 ;;
        1) COMM_FILE="${COMM_LIST[0]}" ;;
        *) warn "Plusieurs .comm trouvés — sélection du premier :"
           for f in "${COMM_LIST[@]}"; do warn "  $f"; done
           COMM_FILE="${COMM_LIST[0]}" ;;
    esac
fi
COMM_FILE="$(realpath "$COMM_FILE")"
[ -f "$COMM_FILE" ] || { err "Fichier .comm introuvable : $COMM_FILE"; exit 1; }
$QUIET || ok "Commandes: $COMM_FILE"

# ── Fichier .med (optionnel) ──────────────────────────────────────────────────
if [ -z "$MED_FILE" ]; then
    mapfile -t MED_LIST < <(find "$STUDY_DIR" -maxdepth 1 -name "*.med" | sort)
    case ${#MED_LIST[@]} in
        0) : ;;
        1) MED_FILE="${MED_LIST[0]}" ;;
        *) warn "Plusieurs .med trouvés — sélection du premier :"
           for f in "${MED_LIST[@]}"; do warn "  $f"; done
           MED_FILE="${MED_LIST[0]}" ;;
    esac
fi
[ -n "$MED_FILE" ] && MED_FILE="$(realpath "$MED_FILE")"
[ -n "$MED_FILE" ] && { $QUIET || ok "Maillage MED  : $MED_FILE"; }

# ── Fichier .mail (format ASTER natif, optionnel) ─────────────────────────────
if [ -z "$MAIL_FILE" ]; then
    mapfile -t MAIL_LIST < <(find "$STUDY_DIR" -maxdepth 1 -name "*.mail" | sort)
    case ${#MAIL_LIST[@]} in
        0) : ;;
        1) MAIL_FILE="${MAIL_LIST[0]}" ;;
        *) warn "Plusieurs .mail trouvés — sélection du premier :"
           for f in "${MAIL_LIST[@]}"; do warn "  $f"; done
           MAIL_FILE="${MAIL_LIST[0]}" ;;
    esac
fi
[ -n "$MAIL_FILE" ] && MAIL_FILE="$(realpath "$MAIL_FILE")"
[ -n "$MAIL_FILE" ] && { $QUIET || ok "Maillage ASTER: $MAIL_FILE"; }

[ -z "$MED_FILE" ] && [ -z "$MAIL_FILE" ] && \
    warn "Aucun maillage (.med ou .mail) — calcul sans maillage externe ?"

# ══════════════════════════════════════════════════════════════════════════════
#  PRÉPARATION DU SCRATCH (nœud login)
# ══════════════════════════════════════════════════════════════════════════════
$QUIET || section "Préparation du scratch"

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
SCRATCH_DIR="${SCRATCH_BASE}/${USER}/${STUDY_NAME}_${TIMESTAMP}"
LOG_DIR="${SCRATCH_DIR}/logs"

$QUIET || info "Création : $SCRATCH_DIR"
mkdir -p "$SCRATCH_DIR" "$LOG_DIR"

# ── Copie des fichiers ────────────────────────────────────────────────────────
cp "$COMM_FILE" "$SCRATCH_DIR/"
$QUIET || ok "Copié : $(basename "$COMM_FILE")"

if [ -n "$MED_FILE" ]; then
    cp "$MED_FILE" "$SCRATCH_DIR/"
    $QUIET || ok "Copié : $(basename "$MED_FILE")"
fi

if [ -n "$MAIL_FILE" ]; then
    cp "$MAIL_FILE" "$SCRATCH_DIR/"
    $QUIET || ok "Copié : $(basename "$MAIL_FILE")"
fi

# Fichiers annexes optionnels (.py, .dat, .para, .include, .mfront)
for ext in py dat para include mfront; do
    for f in "$STUDY_DIR/"*."$ext"; do
        [ -f "$f" ] && cp "$f" "$SCRATCH_DIR/" && { $QUIET || ok "Copié : $(basename "$f")"; }
    done
done

# ── Génération du fichier .export ─────────────────────────────────────────────
$QUIET || section "Génération du fichier .export"

COMM_BASENAME="$(basename "$COMM_FILE")"
MED_BASENAME="$([ -n "$MED_FILE"   ] && basename "$MED_FILE"   || echo "")"
MAIL_BASENAME="$([ -n "$MAIL_FILE"  ] && basename "$MAIL_FILE"  || echo "")"

MEM_MB=$(echo "$MEM" | awk '/G$/{print $1*1024} /M$/{print $1} /^[0-9]+$/{print $1}')
ASTER_MEM=$(( MEM_MB - 512 ))
[ "$ASTER_MEM" -lt 512 ] && ASTER_MEM=512

TIME_LIMIT_SEC=$(echo "$TIME_LIMIT" | awk -F: '{print $1*3600 + $2*60 + $3}')

EXPORT_FILE="${SCRATCH_DIR}/${STUDY_NAME}.export"
{
    echo "P actions make_etude"
    echo "P mode interactif"
    echo "P version stable"
    echo "P ncpus ${NTASKS}"
    echo "P memory_limit ${ASTER_MEM}"
    echo "P time_limit ${TIME_LIMIT_SEC}"
    echo ""
    echo "F comm ${SCRATCH_DIR}/${COMM_BASENAME}           D  1"
    [ -n "$MED_BASENAME"  ] && echo "F mmed ${SCRATCH_DIR}/${MED_BASENAME}            D 20"
    [ -n "$MAIL_BASENAME" ] && echo "F mail ${SCRATCH_DIR}/${MAIL_BASENAME}           D 20"
    echo "F mess ${SCRATCH_DIR}/${STUDY_NAME}.mess         R  6"
    echo "F resu ${SCRATCH_DIR}/${STUDY_NAME}.resu         R  8"
    echo "F rmed ${SCRATCH_DIR}/${STUDY_NAME}_resu.med     R 80"
} > "$EXPORT_FILE"

if ! $QUIET; then
    ok "Export : $EXPORT_FILE"
    while IFS= read -r line; do info "  $line"; done < "$EXPORT_FILE"
fi

# ── Wrapper Singularity (créé sur le nœud login si image disponible) ──────────
SIF_WRAPPER=""
if [ -f "$SINGULARITY_IMAGE" ] && command -v singularity &>/dev/null; then
    SIF_WRAPPER="${SCRATCH_DIR}/aster_sif_wrapper.sh"
    mkdir -p "${SCRATCH_DIR}/local00"
    # Source salome_prerequisites.sh à l'intérieur du conteneur pour que
    # libmed.so.11 et les autres dépendances Salome soient dans LD_LIBRARY_PATH.
    cat > "$SIF_WRAPPER" <<SIFWRAP
#!/bin/bash
exec singularity exec --bind "${SCRATCH_DIR}/local00:/local00" "${SINGULARITY_IMAGE}" bash -c '. /opt/salome_meca/V2024.1.0_scibian_univ/salome_prerequisites.sh && exec "\$@"' -- "${SINGULARITY_ASTER_EXE}" "\$@"
SIFWRAP
    chmod +x "$SIF_WRAPPER"
    $QUIET || ok "Wrapper Singularity : $SIF_WRAPPER"
fi

# ══════════════════════════════════════════════════════════════════════════════
#  AFFICHAGE RESSOURCES
# ══════════════════════════════════════════════════════════════════════════════
if ! $QUIET; then
    section "Ressources Slurm"
    info "Partition  : $PARTITION"
    info "Nœuds      : $NODES"
    info "Tâches MPI : $NTASKS"
    info "CPUs/tâche : $CPUS"
    info "Mémoire    : $MEM"
    info "Durée max  : $TIME_LIMIT"
    info "Scratch    : $SCRATCH_DIR"
fi

# ══════════════════════════════════════════════════════════════════════════════
#  GÉNÉRATION DU SCRIPT SBATCH
# ══════════════════════════════════════════════════════════════════════════════
JOB_SCRIPT="${SCRATCH_DIR}/job.sh"

cat > "$JOB_SCRIPT" <<SBATCH_SCRIPT
#!/bin/bash
# Job Code_Aster — généré par run_aster le $(date)
# Étude   : ${STUDY_NAME}
# Scratch : ${SCRATCH_DIR}

# ── Directives Slurm ──────────────────────────────────────────────────────────
#SBATCH --job-name=aster_${STUDY_NAME}
#SBATCH --partition=${PARTITION}
#SBATCH --nodes=${NODES}
#SBATCH --ntasks=${NTASKS}
#SBATCH --cpus-per-task=${CPUS}
#SBATCH --mem=${MEM}
#SBATCH --time=${TIME_LIMIT}
#SBATCH --output=${LOG_DIR}/aster_%j.out
#SBATCH --error=${LOG_DIR}/aster_%j.err

# ── Fonctions affichage ───────────────────────────────────────────────────────
ts()  { date '+%H:%M:%S'; }
log() { echo "[\$(ts)] \$*"; }
sep() { echo ""; echo "══════════════════════════════════════════════════════"; echo "  \$*"; echo "══════════════════════════════════════════════════════"; }

# ── Variables Slurm simulées si exécution hors Slurm (mode --local) ───────────
SLURM_JOB_ID="\${SLURM_JOB_ID:-local_\$$}"
SLURM_NTASKS="\${SLURM_NTASKS:-${NTASKS}}"
SLURM_NODELIST="\${SLURM_NODELIST:-localhost}"
SLURM_CPUS_PER_TASK="\${SLURM_CPUS_PER_TASK:-${CPUS}}"

sep "DÉBUT CALCUL CODE_ASTER — \$(date)"
log "Job ID         : \$SLURM_JOB_ID"
log "Étude          : ${STUDY_NAME}"
log "Scratch        : ${SCRATCH_DIR}"
log "Nœuds alloués  : \$SLURM_NODELIST"
log "Tâches MPI     : \$SLURM_NTASKS"
log "CPUs par tâche : \$SLURM_CPUS_PER_TASK"
log "Mémoire/nœud   : ${MEM}"

# ── Chargement de Code_Aster ──────────────────────────────────────────────────
sep "CHARGEMENT CODE_ASTER"

if command -v module &>/dev/null && [ -n "${ASTER_MODULE}" ]; then
    module load "${ASTER_MODULE}" 2>/dev/null \
        && log "Module '${ASTER_MODULE}' chargé." \
        || log "Module '${ASTER_MODULE}' non disponible."
fi

ASTER_EXE=""
for candidate in \
    "${ASTER_ROOT}/bin/run_aster" \
    "${ASTER_ROOT}/bin/as_run" \
    "\$(command -v run_aster 2>/dev/null)" \
    "\$(command -v as_run   2>/dev/null)"
do
    [ -x "\$candidate" ] && { ASTER_EXE="\$candidate"; break; }
done

# Fallback : wrapper Singularity pré-généré sur le nœud login
if [ -z "\$ASTER_EXE" ] && [ -x "${SCRATCH_DIR}/aster_sif_wrapper.sh" ]; then
    log "Code_Aster non trouvé nativement — utilisation du wrapper Singularity"
    log "  Image : ${SINGULARITY_IMAGE}"
    ASTER_EXE="${SCRATCH_DIR}/aster_sif_wrapper.sh"
    log "Exécutable (SIF) : \$ASTER_EXE"
fi

if [ -z "\$ASTER_EXE" ]; then
    log "⚠  Code_Aster introuvable."
    log "   → Définir ASTER_ROOT=/chemin/code_aster avant de relancer."
    log "   → Ou installer Code_Aster, créer un module Lmod, ou fournir SINGULARITY_IMAGE."
    exit 1
fi
log "Exécutable : \$ASTER_EXE"

# ── Lancement du calcul ───────────────────────────────────────────────────────
sep "CALCUL EN COURS"
log "Démarrage : \$(date)"

if [ "\$SLURM_NTASKS" -gt 1 ]; then
    log "Mode parallèle MPI (\$SLURM_NTASKS processus)"
    srun --mpi=pmi2 "\$ASTER_EXE" "${EXPORT_FILE}"
else
    log "Mode séquentiel"
    "\$ASTER_EXE" "${EXPORT_FILE}"
fi
ASTER_RC=\$?

# ── Résumé ────────────────────────────────────────────────────────────────────
sep "RÉSUMÉ FINAL"
if [ "\$ASTER_RC" -eq 0 ]; then
    log "Statut    : SUCCÈS ✓"
else
    log "Statut    : ÉCHEC  ✗  (code \$ASTER_RC)"
fi
log "Étude     : ${STUDY_NAME}"
log "Résultats : ${SCRATCH_DIR}"
log "Log       : ${LOG_DIR}/aster_\${SLURM_JOB_ID}.out"
log "Fin       : \$(date)"

exit \$ASTER_RC
SBATCH_SCRIPT

chmod +x "$JOB_SCRIPT"

# ══════════════════════════════════════════════════════════════════════════════
#  RAPATRIEMENT DES RÉSULTATS → DOSSIER D'ÉTUDE
# ══════════════════════════════════════════════════════════════════════════════
copy_results_back() {
    $QUIET || section "Rapatriement des résultats"
    local copied=0
    for f in \
        "${SCRATCH_DIR}/${STUDY_NAME}.mess" \
        "${SCRATCH_DIR}/${STUDY_NAME}.resu" \
        "${SCRATCH_DIR}/${STUDY_NAME}_resu.med"
    do
        if [ -f "$f" ] && [ -s "$f" ]; then
            cp "$f" "$STUDY_DIR/"
            $QUIET || ok "Rapatrié : $(basename "$f")  →  $STUDY_DIR/"
            (( copied++ )) || true
        fi
    done
    [ "$copied" -eq 0 ] && warn "Aucun fichier résultat trouvé dans $SCRATCH_DIR"
}

# ══════════════════════════════════════════════════════════════════════════════
#  SOUMISSION (Slurm) ou EXÉCUTION DIRECTE (--local)
# ══════════════════════════════════════════════════════════════════════════════
if $LOCAL; then
    $QUIET || section "Exécution locale (sans Slurm)"
    $QUIET || info "Lancement direct : bash $JOB_SCRIPT"
    # En local, srun n'est pas disponible → forcer NTASKS=1 (séquentiel)
    SLURM_NTASKS=1 bash "$JOB_SCRIPT"
    LOCAL_RC=$?
    copy_results_back
    if [ $LOCAL_RC -eq 0 ]; then
        $QUIET || ok "Calcul terminé avec succès."
        $QUIET || info "Résultats : $STUDY_DIR"
    else
        err "Calcul terminé en erreur (code $LOCAL_RC)."
        err "Logs complets : $SCRATCH_DIR/"
        exit $LOCAL_RC
    fi
else
    $QUIET || section "Soumission Slurm"

    JOB_ID=$(sbatch --parsable "$JOB_SCRIPT")

    if [ -z "$JOB_ID" ]; then
        err "Échec de la soumission Slurm."
        exit 1
    fi

    if $QUIET; then
        echo "$JOB_ID"
    else
        ok "Job soumis   : ID = ${BOLD}${JOB_ID}${NC}"
        echo ""
        echo -e "  ${BOLD}Commandes utiles :${NC}"
        echo -e "  squeue -j ${JOB_ID}                                   # état du job"
        echo -e "  tail -f ${LOG_DIR}/aster_${JOB_ID}.out               # logs temps réel"
        echo -e "  scancel ${JOB_ID}                                      # annuler"
        echo -e "  ls ${SCRATCH_DIR}/                                    # résultats"
        echo ""
    fi
fi

# ══════════════════════════════════════════════════════════════════════════════
#  MODE --WAIT : suivi temps réel jusqu'à la fin du job
# ══════════════════════════════════════════════════════════════════════════════
if $WAIT; then
    $QUIET || section "Suivi en temps réel  (Ctrl+C pour détacher)"

    LOG_FILE="${LOG_DIR}/aster_${JOB_ID}.out"
    echo "En attente du démarrage du job..."
    for i in $(seq 1 60); do
        [ -f "$LOG_FILE" ] && break
        sleep 5
        squeue -j "$JOB_ID" -h &>/dev/null || { echo "Job terminé (très rapide)."; break; }
    done

    [ -f "$LOG_FILE" ] && tail -f "$LOG_FILE" &
    TAIL_PID=$!

    while squeue -j "$JOB_ID" -h &>/dev/null; do
        sleep 10
    done
    sleep 3
    kill "$TAIL_PID" 2>/dev/null || true

    EXIT_CODE=$(sacct -j "$JOB_ID" --format=ExitCode --noheader 2>/dev/null \
                | head -1 | tr -d ' ' | cut -d: -f1)
    copy_results_back
    if [ "${EXIT_CODE:-0}" -eq 0 ]; then
        $QUIET || ok "Calcul terminé avec succès."
        $QUIET || info "Résultats : $STUDY_DIR"
        exit 0
    else
        $QUIET || err "Calcul terminé en erreur (code ${EXIT_CODE})."
        exit "${EXIT_CODE}"
    fi
fi
